# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://visa_admin:visa_secure_2024@localhost:5432/visa_workflow?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=change-this-to-a-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

ENCRYPTION_KEY=change-to-32-byte-hex-key
ENCRYPTION_IV=change-to-16-byte

LOG_LEVEL=debug
LOG_FORMAT=json

CORS_ORIGIN=http://localhost:3001

BULL_RECONCILIATION_CRON=0 */6 * * *
BULL_GHOST_CHECK_CRON=*/30 * * * *
